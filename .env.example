# YouTube API credentials
# Get these from: https://console.cloud.google.com/
#
# Steps:
# 1. Create a project in Google Cloud Console
# 2. Enable "YouTube Data API v3"
# 3. Go to Credentials → Create Credentials → API Key
# 4. Copy your Channel ID from your YouTube channel URL
#    (it starts with "UC..." or use https://commentpicker.com/youtube-channel-id.php)

PUBLIC_YOUTUBE_API_KEY=your_api_key_here
PUBLIC_YOUTUBE_CHANNEL_ID=your_channel_id_here
