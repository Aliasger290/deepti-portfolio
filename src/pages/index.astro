---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";

const API_KEY = import.meta.env.PUBLIC_YOUTUBE_API_KEY;
const CHANNEL_ID = import.meta.env.PUBLIC_YOUTUBE_CHANNEL_ID;
---

<Layout
  title="YOUR FRIEND'S NAME — Film & Video Editor"
  description="Film and video editor portfolio — commercials, documentaries, narrative films, and branded content."
>
  <Header />

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="hero-inner">
        <p class="hero-eyebrow animate-fade-up animate-fade-up-delay-1">Film & Video Editor</p>
        <h1 class="hero-name animate-fade-up animate-fade-up-delay-2">YOUR FRIEND'S NAME</h1>
        <p class="hero-tagline animate-fade-up animate-fade-up-delay-3">
          Crafting stories through the art of editing.
        </p>
      </div>
    </section>

    <!-- Work Section -->
    <section class="work-section">
      <div class="section-inner">
        <div class="section-header">
          <h2 class="section-label">Selected Work</h2>
        </div>

        <!-- Loading state -->
        <div id="videos-loading" class="loading-state">
          <div class="loading-grid">
            {Array.from({ length: 6 }).map(() => (
              <div class="skeleton-card">
                <div class="skeleton-thumb"></div>
                <div class="skeleton-info">
                  <div class="skeleton-line skeleton-line--long"></div>
                  <div class="skeleton-line skeleton-line--short"></div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Video grid (populated by JS) -->
        <div id="videos-grid" class="hidden"></div>

        <!-- Error state -->
        <div id="videos-error" class="hidden empty-state">
          <p class="empty-title">Could not load videos</p>
          <p class="empty-sub">Check back soon or visit the <a href="https://www.youtube.com/@yourchannel" target="_blank" rel="noopener noreferrer" class="yt-link">YouTube channel</a> directly.</p>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <p class="footer-copy">&copy; {new Date().getFullYear()} YOUR FRIEND'S NAME</p>
      <div class="footer-links">
        <a href="/about" class="footer-link">About</a>
        <a href="/contact" class="footer-link">Contact</a>
      </div>
    </div>
  </footer>
</Layout>

<!-- Client-side video fetching -->
<script define:vars={{ API_KEY, CHANNEL_ID }}>
  async function loadVideos() {
    const loadingEl = document.getElementById("videos-loading");
    const gridEl = document.getElementById("videos-grid");
    const errorEl = document.getElementById("videos-error");

    if (!API_KEY || !CHANNEL_ID) {
      loadingEl?.classList.add("hidden");
      errorEl?.classList.remove("hidden");
      return;
    }

    try {
      // Step 1: Get uploads playlist
      const channelRes = await fetch(
        `https://www.googleapis.com/youtube/v3/channels?part=contentDetails&id=${CHANNEL_ID}&key=${API_KEY}`
      );
      const channelData = await channelRes.json();

      if (channelData.error || !channelData.items?.length) {
        throw new Error("Channel not found");
      }

      const uploadsPlaylistId =
        channelData.items[0].contentDetails.relatedPlaylists.uploads;

      // Step 2: Get videos
      const playlistRes = await fetch(
        `https://www.googleapis.com/youtube/v3/playlistItems?part=snippet&playlistId=${uploadsPlaylistId}&maxResults=24&key=${API_KEY}`
      );
      const playlistData = await playlistRes.json();

      if (playlistData.error || !playlistData.items) {
        throw new Error("Could not fetch playlist");
      }

      const videos = playlistData.items.map((item) => {
        const snippet = item.snippet;
        const videoId = snippet.resourceId.videoId;
        const thumbnails = snippet.thumbnails;
        return {
          id: videoId,
          title: snippet.title,
          thumbnail:
            thumbnails.maxres?.url ||
            thumbnails.high?.url ||
            thumbnails.medium?.url ||
            thumbnails.default?.url,
          publishedAt: snippet.publishedAt,
          embedUrl: `https://www.youtube.com/embed/${videoId}`,
        };
      });

      // Render video cards
      if (gridEl) {
        gridEl.innerHTML = `
          <div class="video-grid">
            ${videos
              .map(
                (video, i) => `
              <button
                class="video-card"
                data-embed-url="${video.embedUrl}"
                data-video-title="${video.title.replace(/"/g, "&quot;")}"
                style="animation-delay: ${(i % 6) * 0.07}s"
                aria-label="Play ${video.title.replace(/"/g, "&quot;")}"
              >
                <div class="video-thumb">
                  <img src="${video.thumbnail}" alt="${video.title.replace(/"/g, "&quot;")}" loading="lazy" decoding="async" />
                  <div class="thumb-gradient"></div>
                  <div class="thumb-overlay">
                    <div class="play-btn">
                      <svg width="20" height="20" fill="black" viewBox="0 0 24 24">
                        <path d="M8 5v14l11-7z"/>
                      </svg>
                    </div>
                  </div>
                </div>
                <div class="video-info">
                  <h3 class="video-title">${video.title}</h3>
                  <time class="video-date">
                    ${new Date(video.publishedAt).toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "short",
                    })}
                  </time>
                </div>
              </button>
            `
              )
              .join("")}
          </div>
        `;

        // Attach click handlers for modal
        gridEl.querySelectorAll(".video-card").forEach((card) => {
          card.addEventListener("click", () => {
            const embedUrl = card.getAttribute("data-embed-url");
            const title = card.getAttribute("data-video-title");
            openModal(embedUrl, title);
          });
        });
      }

      loadingEl?.classList.add("hidden");
      gridEl?.classList.remove("hidden");
    } catch (err) {
      console.error("Failed to load videos:", err);
      loadingEl?.classList.add("hidden");
      errorEl?.classList.remove("hidden");
    }
  }

  // Modal logic
  function openModal(embedUrl, title) {
    const modal = document.getElementById("video-modal");
    const iframe = document.getElementById("modal-iframe");
    const titleEl = document.getElementById("modal-title");
    if (!modal || !iframe || !titleEl) return;
    iframe.src = `${embedUrl}?autoplay=1&rel=0&modestbranding=1`;
    titleEl.textContent = title;
    modal.classList.add("open");
    document.body.style.overflow = "hidden";
  }

  function closeModal() {
    const modal = document.getElementById("video-modal");
    const iframe = document.getElementById("modal-iframe");
    if (!modal || !iframe) return;
    iframe.src = "";
    modal.classList.remove("open");
    document.body.style.overflow = "";
  }

  // Init
  loadVideos();

  // Modal listeners
  document.getElementById("modal-close")?.addEventListener("click", closeModal);
  document.querySelector(".modal-backdrop")?.addEventListener("click", closeModal);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });
</script>

<!-- Modal (shared with VideoGrid component style) -->
<div id="video-modal" class="modal" role="dialog" aria-modal="true">
  <div class="modal-backdrop"></div>
  <div class="modal-content">
    <div class="modal-header">
      <p id="modal-title" class="modal-title-text"></p>
      <button id="modal-close" class="modal-close-btn" aria-label="Close video">
        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
          <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
        </svg>
      </button>
    </div>
    <div class="modal-player">
      <iframe id="modal-iframe" src="" title="Video player" frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen></iframe>
    </div>
  </div>
</div>

<style>
  .hidden { display: none !important; }

  /* Hero */
  .hero {
    padding-top: 160px;
    padding-bottom: 80px;
    padding-left: 2rem;
    padding-right: 2rem;
  }
  .hero-inner { max-width: 1280px; margin: 0 auto; }
  .hero-eyebrow {
    font-size: 0.75rem; font-weight: 500;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: #555; margin-bottom: 1.25rem;
  }
  .hero-name {
    font-size: clamp(2.8rem, 7vw, 6rem);
    font-weight: 700; letter-spacing: -0.03em;
    line-height: 1; color: #f5f5f5; margin-bottom: 1.5rem;
  }
  .hero-tagline {
    font-size: 1rem; color: #555;
    font-weight: 400; max-width: 360px; line-height: 1.6;
  }

  /* Work section */
  .work-section { padding: 0 2rem 8rem; }
  .section-inner { max-width: 1280px; margin: 0 auto; }
  .section-header {
    display: flex; align-items: center;
    margin-bottom: 2.5rem; padding-bottom: 1.25rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .section-label {
    font-size: 0.7rem; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase; color: #444;
  }

  /* Skeleton loading */
  .loading-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }
  @media (min-width: 1024px) {
    .loading-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @keyframes shimmer {
    0% { background-position: -1000px 0; }
    100% { background-position: 1000px 0; }
  }
  .skeleton-card {
    border-radius: 10px; overflow: hidden;
    background: #111; border: 1px solid rgba(255,255,255,0.06);
  }
  .skeleton-thumb {
    aspect-ratio: 16/9;
    background: linear-gradient(90deg, #1a1a1a 25%, #242424 50%, #1a1a1a 75%);
    background-size: 1000px 100%;
    animation: shimmer 1.5s infinite linear;
  }
  .skeleton-info { padding: 1rem 1.1rem 1.1rem; }
  .skeleton-line {
    height: 12px; border-radius: 4px; margin-bottom: 8px;
    background: linear-gradient(90deg, #1a1a1a 25%, #242424 50%, #1a1a1a 75%);
    background-size: 1000px 100%;
    animation: shimmer 1.5s infinite linear;
  }
  .skeleton-line--long { width: 85%; }
  .skeleton-line--short { width: 40%; margin-bottom: 0; }

  /* Video grid (rendered by JS) */
  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }
  @media (min-width: 1024px) {
    .video-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @keyframes cardFadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .video-card {
    background: #111111; border: none; padding: 0; cursor: pointer;
    text-align: left; border-radius: 10px; overflow: hidden;
    border: 1px solid rgba(255,255,255,0.06);
    transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
    animation: cardFadeIn 0.5s ease both;
    display: block; width: 100%;
  }
  .video-card:hover {
    border-color: rgba(255,255,255,0.16);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.08);
  }
  .video-thumb {
    position: relative; aspect-ratio: 16/9;
    overflow: hidden; background: #0d0d0d;
  }
  .video-thumb img {
    width: 100%; height: 100%; object-fit: cover;
    display: block; transition: transform 0.5s ease;
  }
  .video-card:hover .video-thumb img { transform: scale(1.04); }
  .thumb-gradient {
    position: absolute; bottom: 0; left: 0; right: 0; height: 60%;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 100%);
    pointer-events: none;
  }
  .thumb-overlay {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    background: rgba(0,0,0,0); transition: background 0.3s ease;
  }
  .video-card:hover .thumb-overlay { background: rgba(0,0,0,0.35); }
  .play-btn {
    width: 52px; height: 52px; border-radius: 50%;
    background: rgba(255,255,255,0.95);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transform: scale(0.8);
    transition: opacity 0.25s ease, transform 0.25s ease;
    box-shadow: 0 4px 20px rgba(0,0,0,0.4);
    padding-left: 3px;
  }
  .video-card:hover .play-btn { opacity: 1; transform: scale(1); }
  .video-info { padding: 1rem 1.1rem 1.1rem; }
  .video-title {
    font-size: 0.875rem; font-weight: 500; color: #d0d0d0;
    line-height: 1.45;
    display: -webkit-box; -webkit-line-clamp: 2;
    -webkit-box-orient: vertical; overflow: hidden;
    margin-bottom: 0.4rem; transition: color 0.2s ease;
  }
  .video-card:hover .video-title { color: #f5f5f5; }
  .video-date { font-size: 0.75rem; color: #555; letter-spacing: 0.02em; }

  /* Empty / error state */
  .empty-state { text-align: center; padding: 6rem 0; }
  .empty-title { font-size: 1.1rem; color: #444; margin-bottom: 0.5rem; }
  .empty-sub { font-size: 0.875rem; color: #333; }
  .yt-link { color: #888; text-decoration: underline; }
  .yt-link:hover { color: #f5f5f5; }

  /* Modal */
  .modal {
    display: none; position: fixed; inset: 0; z-index: 200;
    align-items: center; justify-content: center; padding: 1.5rem;
  }
  .modal.open { display: flex; }
  .modal-backdrop {
    position: absolute; inset: 0;
    background: rgba(0,0,0,0.92);
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
  }
  .modal-content {
    position: relative; z-index: 1;
    width: 100%; max-width: 1000px;
    animation: modalIn 0.25s ease;
  }
  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.97); }
    to { opacity: 1; transform: scale(1); }
  }
  .modal-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 0.875rem; gap: 1rem;
  }
  .modal-title-text {
    font-size: 0.8125rem; color: #666;
    flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .modal-close-btn {
    width: 34px; height: 34px; border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.06); color: #aaa;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; transition: background 0.2s, color 0.2s;
  }
  .modal-close-btn:hover { background: rgba(255,255,255,0.12); color: #fff; }
  .modal-player {
    position: relative; aspect-ratio: 16/9; background: #000;
    border-radius: 10px; overflow: hidden;
    box-shadow: 0 30px 80px rgba(0,0,0,0.8);
  }
  .modal-player iframe {
    position: absolute; inset: 0; width: 100%; height: 100%; border: none;
  }

  /* Footer */
  .site-footer { border-top: 1px solid rgba(255,255,255,0.06); padding: 2rem; }
  .footer-inner {
    max-width: 1280px; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between;
  }
  .footer-copy { font-size: 0.8125rem; color: #444; }
  .footer-links { display: flex; gap: 1.5rem; }
  .footer-link {
    font-size: 0.8125rem; color: #444; text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-link:hover { color: #f5f5f5; }
</style>
