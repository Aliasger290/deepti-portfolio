---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import { projects, getEmbedUrl, getThumbnailUrl } from "../lib/projects.js";
---

<Layout
  title="Deepti Valunjkar — Film Editor"
  description="Film editor trained at FTII. Specialising in narrative storytelling across independent and commercial projects."
>
  <Header />

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="hero-inner">
        <p class="hero-eyebrow animate-fade-up animate-fade-up-delay-1">Film Editor</p>
        <h1 class="hero-name animate-fade-up animate-fade-up-delay-2">Deepti Valunjkar</h1>
        <p class="hero-tagline animate-fade-up animate-fade-up-delay-3">
          Structure, rhythm, and emotional continuity — shaping footage into stories that resonate.
        </p>
      </div>
    </section>

    <!-- Work Section -->
    <section class="work-section">
      <div class="section-inner">
        <div class="section-header">
          <h2 class="section-label">Selected Work</h2>
          <span class="section-count">{projects.length} projects</span>
        </div>

        <div class="video-grid">
          {projects.map((project, i) => (
            <button
              class="video-card"
              data-embed-url={getEmbedUrl(project)}
              data-title={project.title}
              data-source={project.source}
              style={`animation-delay: ${(i % 6) * 0.07}s`}
              aria-label={`Watch ${project.title}`}
            >
              <!-- Thumbnail -->
              <div class="video-thumb">
                <img
                  src={getThumbnailUrl(project)}
                  alt={project.title}
                  loading="lazy"
                  decoding="async"
                  onerror="this.style.display='none'"
                />
                <div class="thumb-gradient"></div>
                <!-- Source badge -->
                <div class="source-badge">
                  {project.source === "youtube" ? (
                    <svg width="12" height="12" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                    </svg>
                  ) : (
                    <svg width="12" height="12" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M8 5v14l11-7z"/>
                    </svg>
                  )}
                </div>
                <!-- Play overlay -->
                <div class="thumb-overlay">
                  <div class="play-btn">
                    <svg width="20" height="20" fill="black" viewBox="0 0 24 24">
                      <path d="M8 5v14l11-7z"/>
                    </svg>
                  </div>
                </div>
              </div>

              <!-- Info -->
              <div class="video-info">
                <h3 class="video-title">{project.title}</h3>
                <p class="video-meta">
                  <span class="video-category">{project.category}</span>
                  <span class="video-role">{project.role}</span>
                </p>
              </div>
            </button>
          ))}
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <p class="footer-copy">&copy; {new Date().getFullYear()} Deepti Valunjkar</p>
      <div class="footer-links">
        <a href="/about" class="footer-link">About</a>
        <a href="/contact" class="footer-link">Contact</a>
      </div>
    </div>
  </footer>

  <!-- Video Modal -->
  <div id="video-modal" class="modal" role="dialog" aria-modal="true">
    <div class="modal-backdrop"></div>
    <div class="modal-content">
      <div class="modal-header">
        <p id="modal-title" class="modal-title-text"></p>
        <button id="modal-close" class="modal-close-btn" aria-label="Close video">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
          </svg>
        </button>
      </div>
      <div class="modal-player">
        <iframe
          id="modal-iframe"
          src=""
          title="Video player"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </div>
</Layout>

<script>
  const cards = document.querySelectorAll<HTMLElement>(".video-card");
  const modal = document.getElementById("video-modal");
  const backdrop = modal?.querySelector(".modal-backdrop");
  const iframe = document.getElementById("modal-iframe") as HTMLIFrameElement;
  const titleEl = document.getElementById("modal-title");
  const closeBtn = document.getElementById("modal-close");

  function openModal(embedUrl: string, title: string) {
    if (!modal || !iframe || !titleEl) return;
    iframe.src = embedUrl;
    titleEl.textContent = title;
    modal.classList.add("open");
    document.body.style.overflow = "hidden";
  }

  function closeModal() {
    if (!modal || !iframe) return;
    iframe.src = "";
    modal.classList.remove("open");
    document.body.style.overflow = "";
  }

  cards.forEach((card) => {
    card.addEventListener("click", () => {
      const embedUrl = card.dataset.embedUrl || "";
      const title = card.dataset.title || "";
      openModal(embedUrl, title);
    });
  });

  closeBtn?.addEventListener("click", closeModal);
  backdrop?.addEventListener("click", closeModal);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });
</script>

<style>
  /* Hero */
  .hero {
    padding: 160px 2rem 80px;
  }
  .hero-inner { max-width: 1280px; margin: 0 auto; }
  .hero-eyebrow {
    font-size: 0.75rem; font-weight: 500;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: #555; margin-bottom: 1.25rem;
  }
  .hero-name {
    font-size: clamp(2.8rem, 7vw, 6rem);
    font-weight: 700; letter-spacing: -0.03em;
    line-height: 1; color: #f5f5f5; margin-bottom: 1.5rem;
  }
  .hero-tagline {
    font-size: 1rem; color: #555;
    max-width: 480px; line-height: 1.65;
  }

  /* Work section */
  .work-section { padding: 0 2rem 8rem; }
  .section-inner { max-width: 1280px; margin: 0 auto; }
  .section-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 2.5rem; padding-bottom: 1.25rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .section-label {
    font-size: 0.7rem; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase; color: #444;
  }
  .section-count {
    font-size: 0.75rem; color: #333;
  }

  /* Video Grid */
  .video-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 900px) {
    .video-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .video-grid { grid-template-columns: 1fr; }
  }

  @keyframes cardFadeIn {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .video-card {
    background: #111; border: none; padding: 0;
    cursor: pointer; text-align: left;
    border-radius: 10px; overflow: hidden;
    border: 1px solid rgba(255,255,255,0.06);
    transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
    animation: cardFadeIn 0.5s ease both;
    display: block; width: 100%;
  }
  .video-card:hover {
    border-color: rgba(255,255,255,0.16);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.5);
  }

  .video-thumb {
    position: relative; aspect-ratio: 16/9;
    overflow: hidden; background: #0d0d0d;
  }
  .video-thumb img {
    width: 100%; height: 100%; object-fit: cover;
    display: block; transition: transform 0.5s ease;
  }
  .video-card:hover .video-thumb img { transform: scale(1.04); }

  .thumb-gradient {
    position: absolute; bottom: 0; left: 0; right: 0; height: 50%;
    background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 100%);
    pointer-events: none;
  }

  /* Source badge (bottom-left) */
  .source-badge {
    position: absolute; bottom: 8px; left: 8px;
    width: 24px; height: 24px; border-radius: 6px;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(4px);
    display: flex; align-items: center; justify-content: center;
    color: rgba(255,255,255,0.6);
  }

  /* Play overlay */
  .thumb-overlay {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    background: rgba(0,0,0,0); transition: background 0.3s ease;
  }
  .video-card:hover .thumb-overlay { background: rgba(0,0,0,0.35); }
  .play-btn {
    width: 52px; height: 52px; border-radius: 50%;
    background: rgba(255,255,255,0.95);
    display: flex; align-items: center; justify-content: center;
    padding-left: 3px;
    opacity: 0; transform: scale(0.8);
    transition: opacity 0.25s ease, transform 0.25s ease;
    box-shadow: 0 4px 20px rgba(0,0,0,0.4);
  }
  .video-card:hover .play-btn { opacity: 1; transform: scale(1); }

  /* Card info */
  .video-info { padding: 0.9rem 1rem 1rem; }
  .video-title {
    font-size: 0.875rem; font-weight: 500; color: #d0d0d0;
    line-height: 1.4; margin-bottom: 0.35rem;
    display: -webkit-box; -webkit-line-clamp: 2;
    -webkit-box-orient: vertical; overflow: hidden;
    transition: color 0.2s;
  }
  .video-card:hover .video-title { color: #f5f5f5; }
  .video-meta {
    display: flex; flex-direction: column; gap: 0.1rem;
  }
  .video-category { font-size: 0.7rem; color: #555; }
  .video-role { font-size: 0.7rem; color: #444; }

  /* Modal */
  .modal {
    display: none; position: fixed; inset: 0; z-index: 200;
    align-items: center; justify-content: center; padding: 1.5rem;
  }
  .modal.open { display: flex; }
  .modal-backdrop {
    position: absolute; inset: 0;
    background: rgba(0,0,0,0.92);
    backdrop-filter: blur(8px);
  }
  .modal-content {
    position: relative; z-index: 1;
    width: 100%; max-width: 1000px;
    animation: modalIn 0.25s ease;
  }
  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.97); }
    to { opacity: 1; transform: scale(1); }
  }
  .modal-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 0.875rem; gap: 1rem;
  }
  .modal-title-text {
    font-size: 0.8125rem; color: #666;
    flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .modal-close-btn {
    width: 34px; height: 34px; border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.06); color: #aaa;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; transition: background 0.2s, color 0.2s;
  }
  .modal-close-btn:hover { background: rgba(255,255,255,0.12); color: #fff; }
  .modal-player {
    position: relative; aspect-ratio: 16/9;
    background: #000; border-radius: 10px; overflow: hidden;
    box-shadow: 0 30px 80px rgba(0,0,0,0.8);
  }
  .modal-player iframe {
    position: absolute; inset: 0; width: 100%; height: 100%; border: none;
  }

  /* Footer */
  .site-footer { border-top: 1px solid rgba(255,255,255,0.06); padding: 2rem; }
  .footer-inner {
    max-width: 1280px; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between;
  }
  .footer-copy { font-size: 0.8125rem; color: #444; }
  .footer-links { display: flex; gap: 1.5rem; }
  .footer-link {
    font-size: 0.8125rem; color: #444; text-decoration: none;
    transition: color 0.2s;
  }
  .footer-link:hover { color: #f5f5f5; }
</style>
