---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import VideoGrid from "../components/VideoGrid.astro";
import { getChannelVideos } from "../lib/youtube.js";

const videos = await getChannelVideos(24);
---

<Layout
  title="YOUR FRIEND'S NAME — Film & Video Editor"
  description="Film and video editor portfolio — commercials, documentaries, narrative films, and branded content."
>
  <Header />

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="hero-inner">
        <p class="hero-eyebrow animate-fade-up animate-fade-up-delay-1">Film & Video Editor</p>
        <h1 class="hero-name animate-fade-up animate-fade-up-delay-2">YOUR FRIEND'S NAME</h1>
        <p class="hero-tagline animate-fade-up animate-fade-up-delay-3">
          Crafting stories through the art of editing.
        </p>
      </div>
    </section>

    <!-- Work Section -->
    <section class="work-section">
      <div class="section-inner">
        <div class="section-header">
          <h2 class="section-label">Selected Work</h2>
        </div>

        {videos.length > 0 ? (
          <VideoGrid videos={videos} />
        ) : (
          <div class="empty-state">
            <p class="empty-title">No videos found</p>
            <p class="empty-sub">
              Add your YouTube API credentials to <code>.env</code> to load videos.
            </p>
          </div>
        )}
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <p class="footer-copy">&copy; {new Date().getFullYear()} YOUR FRIEND'S NAME</p>
      <div class="footer-links">
        <a href="/about" class="footer-link">About</a>
        <a href="/contact" class="footer-link">Contact</a>
      </div>
    </div>
  </footer>
</Layout>

<style>
  /* Hero */
  .hero {
    padding-top: 160px;
    padding-bottom: 80px;
    padding-left: 2rem;
    padding-right: 2rem;
  }

  .hero-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .hero-eyebrow {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #555;
    margin-bottom: 1.25rem;
  }

  .hero-name {
    font-size: clamp(2.8rem, 7vw, 6rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    color: #f5f5f5;
    margin-bottom: 1.5rem;
  }

  .hero-tagline {
    font-size: 1rem;
    color: #555;
    font-weight: 400;
    max-width: 360px;
    line-height: 1.6;
  }

  /* Work section */
  .work-section {
    padding: 0 2rem 8rem;
  }

  .section-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    margin-bottom: 2.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .section-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #444;
  }

  /* Empty state */
  .empty-state {
    text-align: center;
    padding: 6rem 0;
  }

  .empty-title {
    font-size: 1.1rem;
    color: #444;
    margin-bottom: 0.5rem;
  }

  .empty-sub {
    font-size: 0.875rem;
    color: #333;
  }

  .empty-sub code {
    color: #666;
    font-family: monospace;
  }

  /* Footer */
  .site-footer {
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 2rem;
  }

  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-copy {
    font-size: 0.8125rem;
    color: #444;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-link {
    font-size: 0.8125rem;
    color: #444;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-link:hover { color: #f5f5f5; }
</style>
