---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";

const skills = [
  "Adobe Premiere Pro", "After Effects", "DaVinci Resolve",
  "Final Cut Pro", "Motion Graphics", "Color Grading",
  "Sound Design", "4K / 8K Editing", "VFX", "Photoshop",
];

const stats = [
  { value: "X+", label: "Years Experience" },
  { value: "XX+", label: "Projects Completed" },
  { value: "XX+", label: "Clients Served" },
];
---

<Layout
  title="About — YOUR FRIEND'S NAME"
  description="Film and video editor with experience across commercials, documentaries, and narrative projects."
>
  <Header />

  <main class="about-main">

    <!-- Page Header -->
    <section class="page-header animate-fade-up animate-fade-up-delay-1">
      <div class="container">
        <p class="page-eyebrow">About</p>
        <h1 class="page-title">The person<br/>behind the edit.</h1>
      </div>
    </section>

    <!-- Main Content -->
    <section class="about-content">
      <div class="container">
        <div class="about-grid">

          <!-- Left: Image + Stats -->
          <div class="about-left animate-fade-up animate-fade-up-delay-2">
            <!-- Profile Image -->
            <div class="profile-image-wrap">
              <!-- Replace the div below with: <img src="/profile.jpg" alt="YOUR FRIEND'S NAME" class="profile-img" /> -->
              <div class="profile-placeholder">
                <svg width="48" height="48" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                </svg>
                <p>Add profile.jpg<br/>to /public/</p>
              </div>
            </div>

            <!-- Stats -->
            <div class="stats-grid">
              {stats.map(stat => (
                <div class="stat-card">
                  <span class="stat-value">{stat.value}</span>
                  <span class="stat-label">{stat.label}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Right: Bio + Skills + CTA -->
          <div class="about-right animate-fade-up animate-fade-up-delay-3">
            <div class="bio-name-wrap">
              <h2 class="bio-name">YOUR FRIEND'S NAME</h2>
              <span class="bio-role">Film & Video Editor</span>
            </div>

            <div class="bio-text">
              <p>
                Write your bio here. Describe who you are, your passion for filmmaking, and what drives your work as a video editor.
              </p>
              <p>
                Talk about the types of projects you love — commercials, documentaries, narrative films, music videos, branded content — and what makes your approach unique.
              </p>
              <p>
                Mention your philosophy around storytelling, your process, and what clients can expect when working with you.
              </p>
            </div>

            <!-- Skills -->
            <div class="skills-section">
              <h3 class="skills-heading">Tools & Skills</h3>
              <div class="skills-list">
                {skills.map(skill => (
                  <span class="skill-pill">{skill}</span>
                ))}
              </div>
            </div>

            <!-- CTA -->
            <a href="/contact" class="cta-btn">
              Work With Me
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Experience -->
    <section class="experience-section">
      <div class="container">
        <div class="exp-header">
          <h2 class="section-label">Experience</h2>
        </div>

        <div class="exp-list">
          <div class="exp-item">
            <div class="exp-meta">
              <span class="exp-date">2022 — Present</span>
            </div>
            <div class="exp-body">
              <div class="exp-title-row">
                <h3 class="exp-role">Freelance Video Editor</h3>
                <span class="exp-company">Independent</span>
              </div>
              <p class="exp-desc">
                Describe your freelance work, the clients you've served, and notable projects here. What kinds of content do you produce? What results have you achieved?
              </p>
            </div>
          </div>

          <div class="exp-item">
            <div class="exp-meta">
              <span class="exp-date">2020 — 2022</span>
            </div>
            <div class="exp-body">
              <div class="exp-title-row">
                <h3 class="exp-role">Video Editor</h3>
                <span class="exp-company">Previous Company / Studio Name</span>
              </div>
              <p class="exp-desc">
                Describe your role, responsibilities, and key achievements here. What did you learn? What impact did you have?
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <p class="footer-copy">&copy; {new Date().getFullYear()} YOUR FRIEND'S NAME</p>
      <div class="footer-links">
        <a href="/" class="footer-link">Work</a>
        <a href="/contact" class="footer-link">Contact</a>
      </div>
    </div>
  </footer>
</Layout>

<style>
  .about-main {
    padding-top: 68px;
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Page Header */
  .page-header {
    padding: 5rem 0 4rem;
  }

  .page-eyebrow {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #444;
    margin-bottom: 1.25rem;
  }

  .page-title {
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.08;
    color: #f5f5f5;
  }

  /* About grid */
  .about-content {
    padding-bottom: 5rem;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }

  @media (min-width: 900px) {
    .about-grid {
      grid-template-columns: 380px 1fr;
      gap: 5rem;
    }
  }

  /* Profile image */
  .profile-image-wrap {
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 4/5;
    background: #111;
    border: 1px solid rgba(255,255,255,0.06);
    margin-bottom: 1.5rem;
  }

  .profile-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    color: #333;
    font-size: 0.8125rem;
    text-align: center;
    line-height: 1.5;
  }

  /* For real image: */
  :global(.profile-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Stats */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 10px;
    overflow: hidden;
  }

  .stat-card {
    background: #111;
    padding: 1.25rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .stat-value {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #f5f5f5;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.7rem;
    color: #555;
    line-height: 1.3;
  }

  /* Bio */
  .bio-name-wrap {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .bio-name {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #f5f5f5;
  }

  .bio-role {
    font-size: 0.875rem;
    color: #555;
  }

  .bio-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    color: #777;
    font-size: 0.9375rem;
    line-height: 1.75;
    margin-bottom: 2.5rem;
  }

  /* Skills */
  .skills-section {
    margin-bottom: 2.5rem;
  }

  .skills-heading {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #444;
    margin-bottom: 1rem;
  }

  .skills-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-pill {
    padding: 0.4rem 0.875rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 100px;
    font-size: 0.8125rem;
    color: #999;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
  }

  .skill-pill:hover {
    background: rgba(255,255,255,0.08);
    border-color: rgba(255,255,255,0.16);
    color: #f5f5f5;
  }

  /* CTA */
  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.875rem 1.75rem;
    background: #f5f5f5;
    color: #080808;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s ease, gap 0.2s ease;
  }

  .cta-btn:hover {
    background: #ffffff;
    gap: 0.875rem;
  }

  /* Experience */
  .experience-section {
    padding: 4rem 0 8rem;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .section-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #444;
  }

  .exp-header {
    margin-bottom: 3rem;
  }

  .exp-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 860px;
  }

  .exp-item {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 2rem;
    padding: 2rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    transition: background 0.2s;
  }

  .exp-item:first-child {
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  @media (max-width: 640px) {
    .exp-item {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
  }

  .exp-date {
    font-size: 0.8125rem;
    color: #444;
    padding-top: 2px;
    white-space: nowrap;
  }

  .exp-title-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.625rem;
  }

  .exp-role {
    font-size: 1rem;
    font-weight: 600;
    color: #e0e0e0;
  }

  .exp-company {
    font-size: 0.8125rem;
    color: #555;
  }

  .exp-desc {
    font-size: 0.875rem;
    color: #666;
    line-height: 1.7;
  }

  /* Footer */
  .site-footer {
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 2rem;
  }

  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-copy {
    font-size: 0.8125rem;
    color: #444;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-link {
    font-size: 0.8125rem;
    color: #444;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-link:hover { color: #f5f5f5; }
</style>
