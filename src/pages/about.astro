---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";

const skills = [
  "Avid Media Composer",
  "Adobe Premiere Pro",
  "DaVinci Resolve",
  "Narrative Editing",
  "Documentary Editing",
  "Color Grading",
  "Sound Design",
  "Motion Graphics",
];

const highlights = [
  {
    title: "Tohfa",
    detail: "Official selection — Indian Film Festival Stuttgart & ImagineIndia Film Festival, Madrid 2025",
  },
  {
    title: "FTII International Exchange",
    detail: "Selected for documentary filmmaking exchange programme in Belgium",
  },
  {
    title: "So Mini Things by Aiyyo Shraddha",
    detail: "Stand-up comedy special — Offline & On-Location Editor",
  },
];
---

<Layout
  title="About — Deepti Valunjkar"
  description="Film editor trained at FTII, specialising in narrative storytelling across independent and commercial projects."
>
  <Header />

  <main class="about-main">

    <!-- Page Header -->
    <section class="page-header animate-fade-up animate-fade-up-delay-1">
      <div class="container">
        <p class="page-eyebrow">About</p>
        <h1 class="page-title">The person<br/>behind the edit.</h1>
      </div>
    </section>

    <!-- Main Content -->
    <section class="about-content">
      <div class="container">
        <div class="about-grid">

          <!-- Left: Image + Highlights -->
          <div class="about-left animate-fade-up animate-fade-up-delay-2">
            <!-- Profile Image -->
            <div class="profile-image-wrap">
              <!-- Replace with: <img src="/profile.jpg" alt="Deepti Valunjkar" class="profile-img" /> -->
              <div class="profile-placeholder">
                <svg width="48" height="48" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                </svg>
                <p>Add profile.jpg<br/>to /public/</p>
              </div>
            </div>

            <!-- Notable Highlights -->
            <div class="highlights">
              <p class="highlights-heading">Notable</p>
              {highlights.map(h => (
                <div class="highlight-item">
                  <p class="highlight-title">{h.title}</p>
                  <p class="highlight-detail">{h.detail}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Right: Bio + Skills + CTA -->
          <div class="about-right animate-fade-up animate-fade-up-delay-3">
            <div class="bio-name-wrap">
              <h2 class="bio-name">Deepti Valunjkar</h2>
              <span class="bio-role">Film Editor</span>
            </div>

            <div class="bio-text">
              <p>
                I'm a film editor trained at the Film and Television Institute of India (FTII),
                with a Master's degree in Media and Communication Studies from Savitribai Phule Pune University.
              </p>
              <p>
                Working professionally since 2021, I specialise in narrative storytelling across
                independent and commercial projects. My approach to editing is rooted in structure,
                rhythm, and emotional continuity — shaping footage into stories that feel cohesive,
                immersive, and impactful.
              </p>
              <p>
                I was selected by FTII for an international exchange programme in Belgium, where I
                worked on documentary filmmaking — an experience that broadened my perspective on
                storytelling across cultures and formats.
              </p>
              <p>
                Whether it's a narrative film or digital content, I aim to bring clarity, depth,
                and engagement to every project.
              </p>
            </div>

            <!-- Skills -->
            <div class="skills-section">
              <h3 class="skills-heading">Tools & Skills</h3>
              <div class="skills-list">
                {skills.map(skill => (
                  <span class="skill-pill">{skill}</span>
                ))}
              </div>
            </div>

            <!-- CTA -->
            <a href="/contact" class="cta-btn">
              Work With Me
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Education & Experience -->
    <section class="experience-section">
      <div class="container">
        <div class="exp-header">
          <h2 class="section-label">Education & Experience</h2>
        </div>

        <div class="exp-list">
          <div class="exp-item">
            <div class="exp-meta">
              <span class="exp-date">2021 — Present</span>
            </div>
            <div class="exp-body">
              <div class="exp-title-row">
                <h3 class="exp-role">Freelance Film Editor</h3>
                <span class="exp-company">Independent</span>
              </div>
              <p class="exp-desc">
                Narrative features, short films, documentary, music videos, stand-up comedy specials,
                and branded content. Clients include OMTV App and collaborations with artists such
                as Aiyyo Shraddha.
              </p>
            </div>
          </div>

          <div class="exp-item">
            <div class="exp-meta">
              <span class="exp-date">Exchange Programme</span>
            </div>
            <div class="exp-body">
              <div class="exp-title-row">
                <h3 class="exp-role">International Exchange — Documentary</h3>
                <span class="exp-company">FTII, Belgium</span>
              </div>
              <p class="exp-desc">
                Selected by FTII for an international exchange programme in Belgium focused on
                documentary filmmaking, broadening perspective on cross-cultural storytelling.
              </p>
            </div>
          </div>

          <div class="exp-item">
            <div class="exp-meta">
              <span class="exp-date">FTII Pune</span>
            </div>
            <div class="exp-body">
              <div class="exp-title-row">
                <h3 class="exp-role">Film Editing</h3>
                <span class="exp-company">Film and Television Institute of India</span>
              </div>
              <p class="exp-desc">
                Specialised training in film editing at one of Asia's premier film institutes.
              </p>
            </div>
          </div>

          <div class="exp-item">
            <div class="exp-meta">
              <span class="exp-date">SPPU Pune</span>
            </div>
            <div class="exp-body">
              <div class="exp-title-row">
                <h3 class="exp-role">Master's — Media & Communication Studies</h3>
                <span class="exp-company">Savitribai Phule Pune University</span>
              </div>
              <p class="exp-desc">
                Postgraduate studies in media and communication, building the theoretical foundation
                that informs her editorial practice.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <p class="footer-copy">&copy; {new Date().getFullYear()} Deepti Valunjkar</p>
      <div class="footer-links">
        <a href="/" class="footer-link">Work</a>
        <a href="/contact" class="footer-link">Contact</a>
      </div>
    </div>
  </footer>
</Layout>

<style>
  .about-main { padding-top: 68px; }

  .container { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }

  .page-header { padding: 5rem 0 4rem; }
  .page-eyebrow {
    font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; color: #444; margin-bottom: 1.25rem;
  }
  .page-title {
    font-size: clamp(2.4rem, 5vw, 4rem); font-weight: 700;
    letter-spacing: -0.03em; line-height: 1.08; color: #f5f5f5;
  }

  .about-content { padding-bottom: 5rem; }
  .about-grid {
    display: grid; grid-template-columns: 1fr; gap: 4rem;
  }
  @media (min-width: 900px) {
    .about-grid { grid-template-columns: 340px 1fr; gap: 5rem; }
  }

  /* Profile image */
  .profile-image-wrap {
    border-radius: 12px; overflow: hidden; aspect-ratio: 4/5;
    background: #111; border: 1px solid rgba(255,255,255,0.06);
    margin-bottom: 1.5rem;
  }
  .profile-placeholder {
    width: 100%; height: 100%; display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 1rem;
    color: #333; font-size: 0.8125rem; text-align: center; line-height: 1.5;
  }
  :global(.profile-img) { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* Highlights */
  .highlights { display: flex; flex-direction: column; gap: 0; }
  .highlights-heading {
    font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em;
    text-transform: uppercase; color: #444; margin-bottom: 0.75rem;
  }
  .highlight-item {
    padding: 0.875rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .highlight-item:last-child { border-bottom: none; }
  .highlight-title {
    font-size: 0.8125rem; font-weight: 500; color: #ccc; margin-bottom: 0.2rem;
  }
  .highlight-detail { font-size: 0.75rem; color: #555; line-height: 1.5; }

  /* Bio */
  .bio-name-wrap {
    display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap;
    margin-bottom: 2rem; padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .bio-name { font-size: 1.75rem; font-weight: 700; letter-spacing: -0.02em; color: #f5f5f5; }
  .bio-role { font-size: 0.875rem; color: #555; }

  .bio-text {
    display: flex; flex-direction: column; gap: 1rem;
    color: #777; font-size: 0.9375rem; line-height: 1.75; margin-bottom: 2.5rem;
  }

  /* Skills */
  .skills-section { margin-bottom: 2.5rem; }
  .skills-heading {
    font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em;
    text-transform: uppercase; color: #444; margin-bottom: 1rem;
  }
  .skills-list { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .skill-pill {
    padding: 0.4rem 0.875rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 100px; font-size: 0.8125rem; color: #999;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
  }
  .skill-pill:hover {
    background: rgba(255,255,255,0.08);
    border-color: rgba(255,255,255,0.16); color: #f5f5f5;
  }

  /* CTA */
  .cta-btn {
    display: inline-flex; align-items: center; gap: 0.625rem;
    padding: 0.875rem 1.75rem; background: #f5f5f5; color: #080808;
    font-size: 0.875rem; font-weight: 600; border-radius: 8px;
    text-decoration: none; transition: background 0.2s, gap 0.2s;
  }
  .cta-btn:hover { background: #fff; gap: 0.875rem; }

  /* Experience */
  .experience-section {
    padding: 4rem 0 8rem; border-top: 1px solid rgba(255,255,255,0.06);
  }
  .section-label {
    font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; color: #444;
  }
  .exp-header { margin-bottom: 3rem; }
  .exp-list { display: flex; flex-direction: column; max-width: 860px; }
  .exp-item {
    display: grid; grid-template-columns: 160px 1fr;
    gap: 2rem; padding: 2rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .exp-item:first-child { border-top: 1px solid rgba(255,255,255,0.05); }
  @media (max-width: 640px) {
    .exp-item { grid-template-columns: 1fr; gap: 0.5rem; }
  }
  .exp-date { font-size: 0.8125rem; color: #444; padding-top: 2px; }
  .exp-title-row {
    display: flex; align-items: baseline; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 0.5rem;
  }
  .exp-role { font-size: 1rem; font-weight: 600; color: #e0e0e0; }
  .exp-company { font-size: 0.8125rem; color: #555; }
  .exp-desc { font-size: 0.875rem; color: #666; line-height: 1.7; }

  /* Footer */
  .site-footer { border-top: 1px solid rgba(255,255,255,0.06); padding: 2rem; }
  .footer-inner {
    max-width: 1280px; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between;
  }
  .footer-copy { font-size: 0.8125rem; color: #444; }
  .footer-links { display: flex; gap: 1.5rem; }
  .footer-link {
    font-size: 0.8125rem; color: #444; text-decoration: none; transition: color 0.2s;
  }
  .footer-link:hover { color: #f5f5f5; }
</style>
