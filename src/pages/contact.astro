---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
---

<Layout
  title="Contact — Deepti Valunjkar"
  description="Get in touch to discuss your next film or video project."
>
  <Header />

  <main class="contact-main">

    <!-- Page Header -->
    <section class="page-header animate-fade-up animate-fade-up-delay-1">
      <div class="container">
        <p class="page-eyebrow">Contact</p>
        <h1 class="page-title">Let's make<br/>something great.</h1>
      </div>
    </section>

    <!-- Contact Content -->
    <section class="contact-content animate-fade-up animate-fade-up-delay-2">
      <div class="container">
        <div class="contact-grid">

          <!-- Form -->
          <div class="form-wrap">
            <form
              name="contact"
              method="POST"
              data-netlify="true"
              netlify-honeypot="bot-field"
              class="contact-form"
            >
              <input type="hidden" name="form-name" value="contact" />
              <p class="hidden">
                <label>Don't fill this out: <input name="bot-field" /></label>
              </p>

              <div class="form-row">
                <div class="form-group">
                  <label for="name" class="form-label">Name</label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    placeholder="Your name"
                    class="form-input"
                    autocomplete="name"
                  />
                </div>
                <div class="form-group">
                  <label for="email" class="form-label">Email</label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    placeholder="your@email.com"
                    class="form-input"
                    autocomplete="email"
                  />
                </div>
              </div>

              <div class="form-group">
                <label for="project-type" class="form-label">Project Type</label>
                <div class="select-wrap">
                  <select id="project-type" name="project-type" class="form-input form-select">
                    <option value="" disabled selected>Select project type</option>
                    <option value="commercial">Commercial / Ad</option>
                    <option value="documentary">Documentary</option>
                    <option value="narrative">Narrative / Short Film</option>
                    <option value="music-video">Music Video</option>
                    <option value="branded-content">Branded Content</option>
                    <option value="social-media">Social Media Content</option>
                    <option value="other">Other</option>
                  </select>
                  <svg class="select-chevron" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M6 9l6 6 6-6"/>
                  </svg>
                </div>
              </div>

              <div class="form-group">
                <label for="message" class="form-label">Message</label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="5"
                  placeholder="Tell me about your project..."
                  class="form-input form-textarea"
                ></textarea>
              </div>

              <button type="submit" class="submit-btn">
                <span>Send Message</span>
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </button>
            </form>
          </div>

          <!-- Info Sidebar -->
          <div class="info-sidebar">

            <div class="info-block">
              <h2 class="info-heading">Direct Contact</h2>
              <div class="info-cards">
                <a href="mailto:youremail@example.com" class="info-card">
                  <div class="info-card-icon">
                    <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
                    </svg>
                  </div>
                  <div>
                    <p class="info-card-label">Email</p>
                    <p class="info-card-value">youremail@example.com</p>
                  </div>
                </a>

                <a href="tel:+10000000000" class="info-card">
                  <div class="info-card-icon">
                    <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
                    </svg>
                  </div>
                  <div>
                    <p class="info-card-label">Phone</p>
                    <p class="info-card-value">+1 (000) 000-0000</p>
                  </div>
                </a>
              </div>
            </div>

            <div class="info-block">
              <h2 class="info-heading">Follow My Work</h2>
              <div class="social-links">
                <a href="https://www.youtube.com/@yourchannel" target="_blank" rel="noopener noreferrer" class="social-link">
                  <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                  </svg>
                  <span>YouTube</span>
                  <svg class="link-arrow" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M7 17L17 7M7 7h10v10"/>
                  </svg>
                </a>
                <a href="https://www.instagram.com/yourhandle" target="_blank" rel="noopener noreferrer" class="social-link">
                  <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                  </svg>
                  <span>Instagram</span>
                  <svg class="link-arrow" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M7 17L17 7M7 7h10v10"/>
                  </svg>
                </a>
                <a href="https://www.linkedin.com/in/yourprofile" target="_blank" rel="noopener noreferrer" class="social-link">
                  <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                  <span>LinkedIn</span>
                  <svg class="link-arrow" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M7 17L17 7M7 7h10v10"/>
                  </svg>
                </a>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <p class="footer-copy">&copy; {new Date().getFullYear()} Deepti Valunjkar</p>
      <div class="footer-links">
        <a href="/" class="footer-link">Work</a>
        <a href="/about" class="footer-link">About</a>
      </div>
    </div>
  </footer>
</Layout>

<style>
  .contact-main {
    padding-top: 68px;
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hidden { display: none; }

  /* Page Header */
  .page-header {
    padding: 5rem 0 4rem;
  }

  .page-eyebrow {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #444;
    margin-bottom: 1.25rem;
  }

  .page-title {
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.08;
    color: #f5f5f5;
  }

  /* Contact grid */
  .contact-content {
    padding-bottom: 8rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: start;
  }

  @media (min-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr 320px;
      gap: 5rem;
    }
  }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  @media (max-width: 560px) {
    .form-row { grid-template-columns: 1fr; }
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: #555;
    text-transform: uppercase;
  }

  .form-input {
    width: 100%;
    padding: 0.875rem 1rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    color: #f5f5f5;
    font-size: 0.9375rem;
    font-family: inherit;
    transition: border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
    outline: none;
  }

  .form-input::placeholder {
    color: #3a3a3a;
  }

  .form-input:focus {
    border-color: rgba(255,255,255,0.22);
    background: rgba(255,255,255,0.05);
    box-shadow: 0 0 0 3px rgba(255,255,255,0.04);
  }

  .form-input:hover:not(:focus) {
    border-color: rgba(255,255,255,0.12);
  }

  .form-textarea {
    resize: vertical;
    min-height: 140px;
  }

  /* Select */
  .select-wrap {
    position: relative;
  }

  .form-select {
    appearance: none;
    -webkit-appearance: none;
    cursor: pointer;
    padding-right: 2.5rem;
    background-image: none;
  }

  .form-select option {
    background: #111;
    color: #f5f5f5;
  }

  .select-chevron {
    position: absolute;
    right: 0.875rem;
    top: 50%;
    transform: translateY(-50%);
    color: #555;
    pointer-events: none;
  }

  /* Submit button */
  .submit-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    padding: 0.9rem 1.75rem;
    background: #f5f5f5;
    color: #080808;
    font-size: 0.9rem;
    font-weight: 600;
    font-family: inherit;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.2s, gap 0.2s;
    align-self: flex-start;
    min-width: 160px;
  }

  .submit-btn:hover {
    background: #ffffff;
    gap: 0.875rem;
  }

  /* Info sidebar */
  .info-sidebar {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    position: sticky;
    top: 100px;
  }

  .info-block {}

  .info-heading {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #444;
    margin-bottom: 1.25rem;
  }

  .info-cards {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .info-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.125rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s;
  }

  .info-card:hover {
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.12);
  }

  .info-card-icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: rgba(255,255,255,0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #888;
    flex-shrink: 0;
  }

  .info-card-label {
    font-size: 0.7rem;
    color: #555;
    margin-bottom: 0.2rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .info-card-value {
    font-size: 0.875rem;
    color: #ccc;
    font-weight: 500;
  }

  /* Social links */
  .social-links {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.75rem 0;
    color: #555;
    text-decoration: none;
    font-size: 0.875rem;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    transition: color 0.2s;
  }

  .social-link:last-child { border-bottom: none; }

  .social-link:hover {
    color: #f5f5f5;
  }

  .social-link span {
    flex: 1;
  }

  .link-arrow {
    opacity: 0;
    transition: opacity 0.2s;
  }

  .social-link:hover .link-arrow {
    opacity: 1;
  }

  /* Footer */
  .site-footer {
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 2rem;
  }

  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-copy {
    font-size: 0.8125rem;
    color: #444;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-link {
    font-size: 0.8125rem;
    color: #444;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-link:hover { color: #f5f5f5; }
</style>
