---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
---

<Layout
  title="Contact — Deepti Valunjkar"
  description="Get in touch with Deepti Valunjkar for film editing projects."
>
  <Header />

  <main class="contact-main">

    <section class="page-header animate-fade-up animate-fade-up-delay-1">
      <div class="container">
        <p class="page-eyebrow">Contact</p>
        <h1 class="page-title">Let's make<br/>something great.</h1>
      </div>
    </section>

    <section class="contact-content animate-fade-up animate-fade-up-delay-2">
      <div class="container">

        <div class="contact-grid">

          <!-- Email -->
          <a href="mailto:deeptivalunjkar21@gmail.com" class="contact-card">
            <div class="contact-card-icon">
              <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
              </svg>
            </div>
            <div class="contact-card-body">
              <p class="contact-card-label">Email</p>
              <p class="contact-card-value">deeptivalunjkar21@gmail.com</p>
            </div>
            <svg class="contact-card-arrow" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M7 17L17 7M7 7h10v10"/>
            </svg>
          </a>

          <!-- Instagram -->
          <a href="https://www.instagram.com/deepti_valunjkar/" target="_blank" rel="noopener noreferrer" class="contact-card">
            <div class="contact-card-icon">
              <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </div>
            <div class="contact-card-body">
              <p class="contact-card-label">Instagram</p>
              <p class="contact-card-value">@deepti_valunjkar</p>
            </div>
            <svg class="contact-card-arrow" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M7 17L17 7M7 7h10v10"/>
            </svg>
          </a>

          <!-- LinkedIn -->
          <a href="https://www.linkedin.com/in/deepti-valunjkar-863b18186" target="_blank" rel="noopener noreferrer" class="contact-card">
            <div class="contact-card-icon">
              <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </div>
            <div class="contact-card-body">
              <p class="contact-card-label">LinkedIn</p>
              <p class="contact-card-value">deepti-valunjkar</p>
            </div>
            <svg class="contact-card-arrow" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M7 17L17 7M7 7h10v10"/>
            </svg>
          </a>

          <!-- YouTube -->
          <a href="https://www.youtube.com/@deeptivalunjkar9212" target="_blank" rel="noopener noreferrer" class="contact-card">
            <div class="contact-card-icon">
              <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
            </div>
            <div class="contact-card-body">
              <p class="contact-card-label">YouTube</p>
              <p class="contact-card-value">@deeptivalunjkar9212</p>
            </div>
            <svg class="contact-card-arrow" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M7 17L17 7M7 7h10v10"/>
            </svg>
          </a>

        </div>
      </div>
    </section>

  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <p class="footer-copy">&copy; {new Date().getFullYear()} Deepti Valunjkar</p>
      <div class="footer-links">
        <a href="/" class="footer-link">Work</a>
        <a href="/about" class="footer-link">About</a>
      </div>
    </div>
  </footer>
</Layout>

<style>
  .contact-main { padding-top: 68px; }
  .container { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }

  .page-header { padding: 5rem 0 4rem; }
  .page-eyebrow {
    font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; color: #444; margin-bottom: 1.25rem;
  }
  .page-title {
    font-size: clamp(2.4rem, 5vw, 4rem); font-weight: 700;
    letter-spacing: -0.03em; line-height: 1.08; color: #f5f5f5;
    margin-bottom: 1.25rem;
  }
  .page-sub {
    font-size: 0.9375rem; color: #555; max-width: 400px; line-height: 1.65;
  }

  .contact-content { padding-bottom: 10rem; }

  .contact-grid {
    display: flex; flex-direction: column; gap: 0.75rem;
    max-width: 600px;
  }

  .contact-card {
    display: flex; align-items: center; gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px; text-decoration: none;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
  }
  .contact-card:hover {
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.14);
    transform: translateX(4px);
  }

  .contact-card-icon {
    width: 40px; height: 40px; border-radius: 10px; flex-shrink: 0;
    background: rgba(255,255,255,0.06);
    display: flex; align-items: center; justify-content: center;
    color: #888; transition: color 0.2s;
  }
  .contact-card:hover .contact-card-icon { color: #f5f5f5; }

  .contact-card-body { flex: 1; min-width: 0; }
  .contact-card-label {
    font-size: 0.7rem; color: #555; text-transform: uppercase;
    letter-spacing: 0.08em; margin-bottom: 0.2rem;
  }
  .contact-card-value {
    font-size: 0.9375rem; color: #ccc; font-weight: 500;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  .contact-card-arrow {
    color: #333; flex-shrink: 0; transition: color 0.2s, transform 0.2s;
  }
  .contact-card:hover .contact-card-arrow { color: #888; transform: translate(2px, -2px); }

  /* Footer */
  .site-footer { border-top: 1px solid rgba(255,255,255,0.06); padding: 2rem; }
  .footer-inner {
    max-width: 1280px; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between;
  }
  .footer-copy { font-size: 0.8125rem; color: #444; }
  .footer-links { display: flex; gap: 1.5rem; }
  .footer-link {
    font-size: 0.8125rem; color: #444; text-decoration: none; transition: color 0.2s;
  }
  .footer-link:hover { color: #f5f5f5; }
</style>
