---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: "/", label: "Work" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];

function isActive(href: string) {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}
---

<header id="site-header">
  <div class="header-inner">
    <!-- Logo / Name -->
    <a href="/" class="header-logo">
      Deepti Valunjkar
    </a>

    <!-- Desktop Nav -->
    <nav class="header-nav" aria-label="Main navigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`nav-link ${isActive(link.href) ? "nav-link--active" : ""}`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Desktop Social Icons -->
    <div class="header-social">
      <a
        href="https://www.youtube.com/@yourchannel"
        target="_blank"
        rel="noopener noreferrer"
        class="social-icon"
        aria-label="YouTube"
      >
        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
      </a>
      <a
        href="https://www.instagram.com/yourhandle"
        target="_blank"
        rel="noopener noreferrer"
        class="social-icon"
        aria-label="Instagram"
      >
        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="mobile-menu-btn"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
    <nav class="mobile-nav">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`mobile-nav-link ${isActive(link.href) ? "mobile-nav-link--active" : ""}`}
        >
          {link.label}
        </a>
      ))}
    </nav>
    <div class="mobile-social">
      <a href="https://www.youtube.com/@yourchannel" target="_blank" rel="noopener noreferrer" class="social-icon">
        <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
      </a>
      <a href="https://www.instagram.com/yourhandle" target="_blank" rel="noopener noreferrer" class="social-icon">
        <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
      </a>
    </div>
  </div>
</header>

<style>
  #site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transition: background 0.3s ease, border-color 0.3s ease;
    background: rgba(8, 8, 8, 0);
    border-bottom: 1px solid transparent;
  }

  #site-header.scrolled {
    background: rgba(8, 8, 8, 0.92);
    border-color: rgba(255, 255, 255, 0.07);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .header-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 68px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .header-logo {
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: #f5f5f5;
    text-decoration: none;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }
  .header-logo:hover { color: #ffffff; }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .nav-link {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #666;
    text-decoration: none;
    position: relative;
    transition: color 0.2s ease;
    padding-bottom: 2px;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 1px;
    background: #f5f5f5;
    transform: scaleX(0);
    transition: transform 0.25s ease;
  }
  .nav-link:hover { color: #f5f5f5; }
  .nav-link:hover::after { transform: scaleX(1); }
  .nav-link--active { color: #f5f5f5; }
  .nav-link--active::after { transform: scaleX(1); }

  .header-social {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .social-icon {
    color: #555;
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
  }
  .social-icon:hover { color: #f5f5f5; }

  /* Mobile */
  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .hamburger-line {
    display: block;
    width: 22px;
    height: 1.5px;
    background: #f5f5f5;
    transition: all 0.25s ease;
    transform-origin: center;
  }

  .mobile-menu-btn[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: translateY(3.25px) rotate(45deg);
  }
  .mobile-menu-btn[aria-expanded="true"] .hamburger-line:nth-child(2) {
    transform: translateY(-3.25px) rotate(-45deg);
  }

  .mobile-menu {
    display: none;
    flex-direction: column;
    padding: 1.5rem 2rem 2rem;
    border-top: 1px solid rgba(255,255,255,0.06);
    background: rgba(8, 8, 8, 0.96);
    backdrop-filter: blur(16px);
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 2rem;
  }

  .mobile-nav-link {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: #444;
    text-decoration: none;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    transition: color 0.2s ease;
  }
  .mobile-nav-link:last-child { border-bottom: none; }
  .mobile-nav-link:hover,
  .mobile-nav-link--active { color: #f5f5f5; }

  .mobile-social {
    display: flex;
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .header-nav,
    .header-social {
      display: none;
    }
    .mobile-menu-btn {
      display: flex;
    }
    .mobile-menu.open {
      display: flex;
    }
  }
</style>

<script>
  const header = document.getElementById("site-header");
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");

  // Scroll effect
  window.addEventListener("scroll", () => {
    if (window.scrollY > 20) {
      header?.classList.add("scrolled");
    } else {
      header?.classList.remove("scrolled");
    }
  }, { passive: true });

  // Mobile menu toggle
  btn?.addEventListener("click", () => {
    const isOpen = menu?.classList.contains("open");
    menu?.classList.toggle("open");
    btn.setAttribute("aria-expanded", String(!isOpen));
    menu?.setAttribute("aria-hidden", String(isOpen));
  });

  // Close on nav link click
  menu?.querySelectorAll("a").forEach(link => {
    link.addEventListener("click", () => {
      menu.classList.remove("open");
      btn?.setAttribute("aria-expanded", "false");
      menu.setAttribute("aria-hidden", "true");
    });
  });
</script>
