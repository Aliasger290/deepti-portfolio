---
interface Video {
  id: string;
  title: string;
  description: string;
  thumbnail: {
    default?: string;
    medium?: string;
    high?: string;
    maxres?: string;
  };
  publishedAt: string;
  channelTitle: string;
  embedUrl: string;
  watchUrl: string;
}

interface Props {
  videos: Video[];
}

const { videos } = Astro.props;
---

<div class="video-grid">
  {videos.map((video, i) => (
    <button
      class="video-card"
      data-video-id={video.id}
      data-video-title={video.title}
      data-embed-url={video.embedUrl}
      style={`animation-delay: ${(i % 6) * 0.07}s`}
      aria-label={`Play ${video.title}`}
    >
      <!-- Thumbnail -->
      <div class="video-thumb">
        <img
          src={video.thumbnail.maxres || video.thumbnail.high || video.thumbnail.medium || video.thumbnail.default}
          alt={video.title}
          loading="lazy"
          decoding="async"
        />
        <!-- Gradient overlay always visible at bottom -->
        <div class="thumb-gradient"></div>
        <!-- Play overlay on hover -->
        <div class="thumb-overlay">
          <div class="play-btn">
            <svg width="20" height="20" fill="white" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- Info -->
      <div class="video-info">
        <h3 class="video-title">{video.title}</h3>
        <time class="video-date">
          {new Date(video.publishedAt).toLocaleDateString("en-US", {
            year: "numeric",
            month: "short",
          })}
        </time>
      </div>
    </button>
  ))}
</div>

<!-- Video Modal -->
<div id="video-modal" class="modal" role="dialog" aria-modal="true" aria-label="Video player">
  <div class="modal-backdrop"></div>
  <div class="modal-content">
    <div class="modal-header">
      <p id="modal-title" class="modal-title-text"></p>
      <button id="modal-close" class="modal-close-btn" aria-label="Close video">
        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
          <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
        </svg>
      </button>
    </div>
    <div class="modal-player">
      <iframe
        id="modal-iframe"
        src=""
        title="Video player"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      ></iframe>
    </div>
  </div>
</div>

<style>
  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  @media (min-width: 1024px) {
    .video-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @keyframes cardFadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .video-card {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-align: left;
    border-radius: 10px;
    overflow: hidden;
    background: #111111;
    border: 1px solid rgba(255,255,255,0.06);
    transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
    animation: cardFadeIn 0.5s ease both;
    display: block;
    width: 100%;
  }

  .video-card:hover {
    border-color: rgba(255,255,255,0.16);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.08);
  }

  .video-thumb {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: #0d0d0d;
  }

  .video-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .video-card:hover .video-thumb img {
    transform: scale(1.04);
  }

  .thumb-gradient {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 60%;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 100%);
    pointer-events: none;
  }

  .thumb-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0);
    transition: background 0.3s ease;
  }

  .video-card:hover .thumb-overlay {
    background: rgba(0,0,0,0.35);
  }

  .play-btn {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: rgba(255,255,255,0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: scale(0.8);
    transition: opacity 0.25s ease, transform 0.25s ease;
    box-shadow: 0 4px 20px rgba(0,0,0,0.4);
  }

  .play-btn svg {
    fill: #000;
    margin-left: 3px;
  }

  .video-card:hover .play-btn {
    opacity: 1;
    transform: scale(1);
  }

  .video-info {
    padding: 1rem 1.1rem 1.1rem;
  }

  .video-title {
    font-size: 0.875rem;
    font-weight: 500;
    color: #d0d0d0;
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 0.4rem;
    transition: color 0.2s ease;
  }

  .video-card:hover .video-title {
    color: #f5f5f5;
  }

  .video-date {
    font-size: 0.75rem;
    color: #555;
    letter-spacing: 0.02em;
  }

  /* Modal */
  .modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }

  .modal.open {
    display: flex;
  }

  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .modal-content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1000px;
    animation: modalIn 0.25s ease;
  }

  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.97); }
    to { opacity: 1; transform: scale(1); }
  }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.875rem;
    gap: 1rem;
  }

  .modal-title-text {
    font-size: 0.8125rem;
    color: #666;
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .modal-close-btn {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.06);
    color: #aaa;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.2s, color 0.2s;
  }
  .modal-close-btn:hover {
    background: rgba(255,255,255,0.12);
    color: #fff;
  }

  .modal-player {
    position: relative;
    aspect-ratio: 16/9;
    background: #000;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(0,0,0,0.8);
  }

  .modal-player iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
</style>

<script>
  const cards = document.querySelectorAll<HTMLElement>(".video-card");
  const modal = document.getElementById("video-modal");
  const backdrop = modal?.querySelector(".modal-backdrop");
  const iframe = document.getElementById("modal-iframe") as HTMLIFrameElement;
  const titleEl = document.getElementById("modal-title");
  const closeBtn = document.getElementById("modal-close");

  function openModal(embedUrl: string, title: string) {
    if (!modal || !iframe || !titleEl) return;
    iframe.src = `${embedUrl}?autoplay=1&rel=0&modestbranding=1`;
    titleEl.textContent = title;
    modal.classList.add("open");
    document.body.style.overflow = "hidden";
  }

  function closeModal() {
    if (!modal || !iframe) return;
    iframe.src = "";
    modal.classList.remove("open");
    document.body.style.overflow = "";
  }

  cards.forEach((card) => {
    card.addEventListener("click", () => {
      const embedUrl = card.dataset.embedUrl || "";
      const title = card.dataset.videoTitle || "";
      openModal(embedUrl, title);
    });
  });

  closeBtn?.addEventListener("click", closeModal);
  backdrop?.addEventListener("click", closeModal);

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });
</script>
